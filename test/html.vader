Execute (HTML ReadMap - existing block, reordered attributes, multiline tag):
  let g:res = importmap#html#ReadMap('test/fixtures/html/existing_map.html')
  AssertEqual 1, g:res.found
  AssertEqual 'https://esm.sh/canvas-confetti@1.9.3', g:res.parsed.imports['canvas-confetti']

  let g:reordered = importmap#html#ReadMap('test/fixtures/html/reordered_attrs.html')
  AssertEqual 1, g:reordered.found
  AssertEqual 'https://esm.sh/lodash-es@4.17.21', g:reordered.parsed.imports['lodash-es']

  let g:multiline = importmap#html#ReadMap('test/fixtures/html/multiline_tag.html')
  AssertEqual 1, g:multiline.found
  AssertEqual 'https://esm.sh/canvas-confetti@1.9.3', g:multiline.parsed.imports['canvas-confetti']

Execute (HTML ReadMap - multiple blocks warning and first wins):
  let g:multi = importmap#html#ReadMap('test/fixtures/html/multiple_maps.html')
  AssertEqual 1, g:multi.found
  AssertEqual 'https://esm.sh/canvas-confetti@1.9.3', g:multi.parsed.imports['canvas-confetti']

Execute (HTML ReadMap - error when src= is present):
  let g:tmp = tempname() . '.html'
  call writefile(['<!DOCTYPE html><html><head><script type="importmap" src="external.json"></script></head><body></body></html>'], g:tmp)
  let g:err = ''
  try
    call importmap#html#ReadMap(g:tmp)
  catch
    let g:err = v:exception
  endtry
  Assert g:err =~# 'src=', 'expected the src= error, got: ' . g:err
  call delete(g:tmp)

Execute (HTML ReadMap - data-src is not src):
  let g:tmp = tempname() . '.html'
  call writefile(['<html><head><script type="importmap" data-src="x">{"imports":{}}</script></head></html>'], g:tmp)
  let g:res = importmap#html#ReadMap(g:tmp)
  AssertEqual 1, g:res.found
  call delete(g:tmp)

Execute (HTML ReadMap - malformed JSON abort):
  let g:err = ''
  try
    call importmap#html#ReadMap('test/fixtures/html/malformed_json.html')
  catch
    let g:err = v:exception
  endtry
  Assert g:err !=# '', 'expected abort on malformed JSON'

Execute (HTML ReadMap - minified single-line document):
  let g:tmp = tempname() . '.html'
  call writefile(['<!DOCTYPE html><html><head><meta charset="utf-8"><script type="importmap">{"imports":{"a":"https://esm.sh/a@1.0.0"}}</script></head><body></body></html>'], g:tmp)
  let g:res = importmap#html#ReadMap(g:tmp)
  AssertEqual 1, g:res.found
  AssertEqual 'https://esm.sh/a@1.0.0', g:res.parsed.imports['a']

  let g:map = g:res.parsed
  let g:map.imports['b'] = 'https://esm.sh/b@2.0.0'
  call importmap#html#WriteMap(g:tmp, g:map, g:res)
  AssertEqual 1, len(readfile(g:tmp)), 'a one-line document must stay one line'
  let g:res2 = importmap#html#ReadMap(g:tmp)
  AssertEqual 'https://esm.sh/a@1.0.0', g:res2.parsed.imports['a']
  AssertEqual 'https://esm.sh/b@2.0.0', g:res2.parsed.imports['b']
  call delete(g:tmp)

Execute (HTML ReadMap - a commented-out importmap is skipped):
  let g:tmp = tempname() . '.html'
  call writefile([
    \ '<html><head>',
    \ '<!--',
    \ '<script type="importmap">{"imports":{"stale":"https://esm.sh/stale@1.0.0"}}</script>',
    \ '-->',
    \ '<script type="importmap">{"imports":{"live":"https://esm.sh/live@1.0.0"}}</script>',
    \ '</head><body></body></html>'], g:tmp)
  let g:res = importmap#html#ReadMap(g:tmp)
  AssertEqual 1, g:res.found
  AssertEqual ['live'], keys(g:res.parsed.imports)
  call delete(g:tmp)

Execute (HTML ReadMap - importmap after another script on the same line):
  let g:tmp = tempname() . '.html'
  call writefile(['<html><head><script src="a.js"></script><script type="importmap">{"imports":{"a":"https://esm.sh/a@1.0.0"}}</script></head></html>'], g:tmp)
  let g:res = importmap#html#ReadMap(g:tmp)
  AssertEqual 1, g:res.found
  AssertEqual 'https://esm.sh/a@1.0.0', g:res.parsed.imports['a']
  call delete(g:tmp)

Execute (HTML ReadMap - JSON-file mode):
  let g:json_mode = importmap#html#ReadMap('test/fixtures/html/map.json')
  AssertEqual 1, g:json_mode.found
  AssertEqual 1, g:json_mode.is_json_mode
  AssertEqual 'https://esm.sh/canvas-confetti@1.9.3', g:json_mode.parsed.imports['canvas-confetti']

Execute (HTML Write - insert before module script):
  let g:tmp = tempname() . '.html'
  call writefile(readfile('test/fixtures/html/insert_before_module.html'), g:tmp)
  let g:map = {'imports': {'canvas-confetti': 'https://esm.sh/canvas-confetti@1.9.3'}}
  call importmap#html#WriteMap(g:tmp, g:map, {})
  let g:content = join(readfile(g:tmp), "\n")
  let g:idx_map = stridx(g:content, '<script type="importmap">')
  let g:idx_mod = stridx(g:content, '<script type="module">')
  Assert g:idx_map != -1, 'importmap tag should be inserted'
  Assert g:idx_map < g:idx_mod, 'importmap should be inserted before module script'
  call delete(g:tmp)

Execute (HTML Write - insert before head close):
  let g:tmp = tempname() . '.html'
  call writefile(readfile('test/fixtures/html/insert_before_head_close.html'), g:tmp)
  let g:map = {'imports': {'canvas-confetti': 'https://esm.sh/canvas-confetti@1.9.3'}}
  call importmap#html#WriteMap(g:tmp, g:map, {})
  let g:content = join(readfile(g:tmp), "\n")
  let g:idx_map = stridx(g:content, '<script type="importmap">')
  let g:idx_head_close = stridx(g:content, '</head>')
  Assert g:idx_map != -1, 'importmap tag should be inserted'
  Assert g:idx_map < g:idx_head_close, 'importmap should be inserted before </head>'
  call delete(g:tmp)

Execute (HTML Write - insert after head open):
  let g:tmp = tempname() . '.html'
  call writefile(readfile('test/fixtures/html/insert_after_head_open.html'), g:tmp)
  let g:map = {'imports': {'canvas-confetti': 'https://esm.sh/canvas-confetti@1.9.3'}}
  call importmap#html#WriteMap(g:tmp, g:map, {})
  let g:content = join(readfile(g:tmp), "\n")
  let g:idx_head_open = stridx(g:content, '<head id="main-head" class="header">')
  let g:idx_map = stridx(g:content, '<script type="importmap">')
  Assert g:idx_map != -1, 'importmap tag should be inserted'
  Assert g:idx_head_open < g:idx_map, 'importmap should be inserted after <head ...>'
  call delete(g:tmp)

Execute (HTML Write - insert into a single-line head lands inside it):
  let g:tmp = tempname() . '.html'
  call writefile(['<html>', '<head></head>', '<body></body>', '</html>'], g:tmp)
  call importmap#html#WriteMap(g:tmp, {'imports': {'a': 'https://esm.sh/a@1.0.0'}}, {})
  let g:lines = readfile(g:tmp)
  Assert g:lines[1] =~# '^<head><script type="importmap">.*</script></head>$', 'block must land inside the head element: ' . g:lines[1]
  let g:res = importmap#html#ReadMap(g:tmp)
  AssertEqual 'https://esm.sh/a@1.0.0', g:res.parsed.imports['a']
  call delete(g:tmp)

Execute (HTML Write - error on no head tag):
  let g:tmp = tempname() . '.html'
  call writefile(readfile('test/fixtures/html/no_head.html'), g:tmp)
  let g:map = {'imports': {'canvas-confetti': 'https://esm.sh/canvas-confetti@1.9.3'}}
  let g:err = ''
  try
    call importmap#html#WriteMap(g:tmp, g:map, {})
  catch
