Execute (HTML Write - rewriting keeps the script tag attributes):
  let g:tmp = tempname() . '.html'
  call writefile(readfile('test/fixtures/html/reordered_attrs.html'), g:tmp)
  let g:res = importmap#html#ReadMap(g:tmp)
  let g:map = g:res.parsed
  let g:map.imports['x'] = 'https://esm.sh/x@1.0.0'
  call importmap#html#WriteMap(g:tmp, g:map, g:res)
  let g:content = join(readfile(g:tmp), "\n")
  Assert stridx(g:content, "<script defer type='importmap' id=\"my-map\">") != -1, 'attributes must survive a rewrite'
  call delete(g:tmp)

Execute (HTML Write - a value containing </script> cannot break out of the block):
  let g:tmp = tempname() . '.html'
  call writefile(readfile('test/fixtures/html/existing_map.html'), g:tmp)
  let g:res = importmap#html#ReadMap(g:tmp)
  let g:map = g:res.parsed
  let g:map.imports['evil'] = 'https://cdn.example/</script><script>alert(1)</script>'
  call importmap#html#WriteMap(g:tmp, g:map, g:res)
  let g:content = join(readfile(g:tmp), "\n")
  AssertEqual -1, stridx(g:content, '<script>alert(1)'), 'a raw script tag must not appear in the document'
  let g:res2 = importmap#html#ReadMap(g:tmp)
  AssertEqual 'https://cdn.example/</script><script>alert(1)</script>', g:res2.parsed.imports['evil']
  call delete(g:tmp)

Execute (HTML Write - repeated rewrites are byte-identical):
  let g:tmp = tempname() . '.html'
  call writefile(readfile('test/fixtures/html/existing_map.html', 'b'), g:tmp, 'b')
  for g:i in range(3)
    let g:res = importmap#html#ReadMap(g:tmp)
    call importmap#html#WriteMap(g:tmp, g:res.parsed, g:res)
  endfor
  AssertEqual readfile('test/fixtures/html/existing_map.html', 'b'), readfile(g:tmp, 'b')
  call delete(g:tmp)

Execute (HTML Write - crlf files stay crlf, including the final newline):
  let g:tmp = tempname() . '.html'
  let g:crlf_lines = map(readfile('test/fixtures/html/crlf.html'), 'substitute(v:val, ''\r$'', '''', '''') . nr2char(13)') + ['']
  call writefile(g:crlf_lines, g:tmp, 'b')
  let g:res = importmap#html#ReadMap(g:tmp)
  let g:map = g:res.parsed
  let g:map.imports['new-pkg'] = 'https://esm.sh/new-pkg@1.0.0'
  call importmap#html#WriteMap(g:tmp, g:map, g:res)
  let g:raw = readfile(g:tmp, 'b')
  AssertEqual '', g:raw[-1], 'the final newline must survive'
  for g:line in g:raw[:-2]
    Assert g:line =~# "\r$", 'every line must end in CR, got: ' . strtrans(g:line)
  endfor
  let g:res2 = importmap#html#ReadMap(g:tmp)
  AssertEqual 'https://esm.sh/new-pkg@1.0.0', g:res2.parsed.imports['new-pkg']
  call delete(g:tmp)

Execute (HTML Write - buffer vs disk rule):
  let g:tmp = tempname() . '.html'
  call writefile(readfile('test/fixtures/html/existing_map.html'), g:tmp)
  execute 'edit ' . fnameescape(g:tmp)
  let g:bufnr = bufnr('%')
  let g:res = importmap#html#ReadMap(g:tmp)
  let g:map = g:res.parsed
  let g:map.imports['buf-pkg'] = 'https://esm.sh/buf-pkg@1.0.0'
  call importmap#html#WriteMap(g:tmp, g:map, g:res)

  AssertEqual 1, getbufvar(g:bufnr, '&modified'), 'buffer should be marked modified'
  let g:buf_lines = getbufline(g:bufnr, 1, '$')
  Assert stridx(join(g:buf_lines, "\n"), 'buf-pkg') != -1, 'buffer should contain the new package'

  let g:disk_lines = readfile(g:tmp)
  AssertEqual -1, stridx(join(g:disk_lines, "\n"), 'buf-pkg'), 'disk file should not be modified yet'

  execute 'bwipeout! ' . g:bufnr
  call delete(g:tmp)

Execute (HTML Write - unknown top-level keys survive a round trip):
  let g:tmp = tempname() . '.html'
  call writefile(readfile('test/fixtures/html/unknown_keys.html'), g:tmp)
  let g:res = importmap#html#ReadMap(g:tmp)
  call importmap#html#WriteMap(g:tmp, g:res.parsed, g:res)
  let g:res2 = importmap#html#ReadMap(g:tmp)
  AssertEqual g:res.parsed, g:res2.parsed
  call delete(g:tmp)

Execute (HTML Target Selection - search candidates and priority):
  let g:dir = tempname()
  call mkdir(g:dir, 'p')
  let g:target_file = g:dir . '/index.html'
  call writefile(['<!DOCTYPE html><html><head></head><body></body></html>'], g:target_file)
  let g:old_cwd = getcwd()
  execute 'cd ' . fnameescape(g:dir)
  let g:found = importmap#html#LocateTarget()
  AssertEqual resolve(fnamemodify(g:target_file, ':p')), fnamemodify(g:found, ':p')
  execute 'cd ' . fnameescape(g:old_cwd)
  call delete(g:target_file)
  call delete(g:dir, 'd')
